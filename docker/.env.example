# qiuqiuwriter Docker 部署环境变量
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=writerai
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379
# REDIS_PASSWORD=          # 生产环境建议设置

# ---------- MongoDB ----------
MONGODB_DATABASE=writerai_sharedb
MONGODB_PORT=27017
# MONGODB_USERNAME=       # 可选
# MONGODB_PASSWORD=       # 可选

# ---------- Neo4j ----------
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ---------- 后端（仅在后端以容器方式启动时生效） ----------
BACKEND_PORT=8000

# ---------- 应用连接说明 ----------
# 本机跑应用、仅用 Docker 起中间件时，在应用 .env 中使用：
#   POSTGRES_HOST=localhost  REDIS_HOST=localhost  MONGODB_HOST=localhost
# 应用也跑在 Docker（docker compose up）时，上述已在 compose 中写死为服务名：
#   POSTGRES_HOST=postgres  REDIS_HOST=redis  MONGODB_HOST=mongodb
